# Environment variable template — copy this file to .env.local for local
# development (it's already gitignored). For production, set each variable
# in the Vercel dashboard:
#   Project Settings → Environment Variables → Add Key/Value
#   Set scope to Production (and Preview if desired) → Redeploy.
#
# Never commit a real .env file. The .env, .env.local, .env.*.local
# patterns are all in .gitignore.

# ─────────────────────────────────────────────────────────────────
# Mailchimp — drives the newsletter subscribe form (site footer)
# and the optional subscribe step after the 21+ age gate.
# ─────────────────────────────────────────────────────────────────
#   API key:        Mailchimp dashboard → Account → Extras → API keys
#                   Format: 32-hex-string-dashes-server-prefix
#   Server prefix:  The suffix of your API key (e.g. "us12"). Must match
#                   the API key — Mailchimp routes requests by this prefix.
#   Audience ID:    Mailchimp dashboard → Audience → Settings →
#                   Audience name and defaults → look for "Audience ID"
MAILCHIMP_API_KEY=your-32-hex-string-here-us12
MAILCHIMP_SERVER_PREFIX=us12
MAILCHIMP_AUDIENCE_ID=10charhexid

# ─────────────────────────────────────────────────────────────────
# Base path — PRODUCTION SERVES AT THE SUBDOMAIN ROOT
# (https://nyc.raindropsgreenery.com), so this MUST stay unset in Vercel.
# Setting it would prefix every route while the canonicals, sitemap, and
# JSON-LD still point at the bare subdomain — breaking links. Only ever set
# it if the site is later moved to a sub-path host.
# ─────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_BASE_PATH=

# ─────────────────────────────────────────────────────────────────
# Analytics — uncomment after launch when GA4 + Meta Pixel IDs are
# provisioned. The layout.tsx auto-loads these scripts only when the
# env var is set, so leaving them blank simply skips the integration.
# ─────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_META_PIXEL_ID=XXXXXXXXXXXXXXXX

# ─────────────────────────────────────────────────────────────────
# Subscribers dashboard (/dashboard) — owners-only tool for managing the
# Mailchimp list and giveaway gift tracking. REQUIRED for the dashboard:
#   DASHBOARD_PASSWORD       — the shared owner password (pick something long).
#   DASHBOARD_SESSION_SECRET — optional; 32+ random characters used to sign
#                              session cookies. If unset, a secret is derived
#                              from the password (so changing the password
#                              also logs everyone out).
# Set both in Vercel for Production AND Preview.
# ─────────────────────────────────────────────────────────────────
DASHBOARD_PASSWORD=pick-a-long-owner-password
# DASHBOARD_SESSION_SECRET=

# ─────────────────────────────────────────────────────────────────
# AI chat concierge — OPTIONAL. Without these, the chat widget runs its
# built-in scripted brain (free, no key). Add an Anthropic API key to upgrade
# it to a full Claude-powered assistant that understands any question.
#   ANTHROPIC_API_KEY — secret, set in Vercel env ONLY (never commit it).
#   CHAT_MODEL        — optional model override (defaults to a Claude Haiku).
# ─────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# CHAT_MODEL=claude-3-5-haiku-latest
